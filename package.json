{
  "name": "crud-kick-starter",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first modular CMS runtime workspace",
  "packageManager": "pnpm@10.4.1",
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "infra:live-check": "pnpm --filter server infra:live-check",
    "api-runner:deployment-mission-policy": "pnpm --filter server api-runner:deployment-mission-policy",
    "api-runner:editorial-capability": "pnpm --filter server api-runner:editorial-capability",
    "test:server:core": "pnpm --filter server exec vitest run test/core/core.contract.core.test.js test/core/generated-runtime-singularization.core.test.js test/core/module-scaffolder.singularization.core.test.js test/core/module-scaffolder.route-view.core.test.js test/core/module-scaffolder.field-descriptor.core.test.js test/core/module-scaffolder.generated-descriptor-validation.core.test.js test/core/module-scaffolder.persistence-policy.core.test.js test/core/module-scaffolder.profile-validation.core.test.js test/core/reference-slice.runtime-discovery.core.test.js test/core/reference-slice.runtime-registrar-diagnostics.core.test.js test/core/reference-slice.persistence-mode.core.test.js test/core/system.core.test.js test/core/validation-engine-adapter.core.test.js test/core/remote-config-validation.core.test.js test/core/remote-deploy-mission-validation.core.test.js test/core/reference-module-id-translation.core.test.js test/core/reference-module-id-translation-routes.core.test.js",
    "test:server:core:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=server --lane-group=core",
    "test:server:conformance": "pnpm --filter server exec vitest run test/module-conformance/module-scaffolder.generated-descriptor-fields.module-conformance.test.js test/module-conformance/module-scaffolder.generated-descriptor-behavior.module-conformance.test.js test/module-conformance/module-scaffolder.onboarding.module-conformance.test.js test/module-conformance/reference-slice.runtime-mission-lifecycle.module-conformance.test.js test/module-conformance/reference-slice.generated-runtime-core.module-conformance.test.js test/module-conformance/reference-slice.generated-runtime-validation.module-conformance.test.js test/module-conformance/reference-slice.persistence-restart.module-conformance.test.js test/module-conformance/reference-slice.collections-core-baseline.module-conformance.test.js test/module-conformance/reference-slice.collections-core-crud.module-conformance.test.js test/module-conformance/reference-slice.collections-extended-crud.module-conformance.test.js test/module-conformance/reference-slice.collections-extended-behavior.module-conformance.test.js test/module-conformance/reference-slice.collections-extended-computed.module-conformance.test.js test/module-conformance/reference-slice.delete-policy.module-conformance.test.js test/module-conformance/reference-slice.deploy-remotes.module-conformance.test.js test/module-conformance/reference-slice.iter1.assignment.module-conformance.test.js test/module-conformance/reference-slice.iter2.assignment.module-conformance.test.js test/module-conformance/reference-slice.iter3.assignment.module-conformance.test.js test/module-conformance/reference-slice.iter4.assignment.module-conformance.test.js test/module-conformance/reference-slice.iter5.assignment.module-conformance.test.js test/module-conformance/reference-slice.module-settings.owner.conformance.test.js test/module-conformance/reference-options-provider-lifecycle.conformance.test.js",
    "test:server:conformance:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=server --lane-group=conformance",
    "test:server:runtime-integration": "pnpm --filter server exec vitest run test/runtime-integration/infra.degraded.runtime-integration.test.js test/runtime-integration/infra.live.runtime-integration.test.js test/runtime-integration/mongo.live-persistence.runtime-integration.test.js test/runtime-integration/deployment-mission-policy-api-runner.runtime-integration.test.js test/runtime-integration/editorial-capability-api-runner.runtime-integration.test.js",
    "test:server:runtime-integration:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=server --lane-group=runtime",
    "test:frontend:core": "pnpm --filter frontend exec vitest run src/tests/core/view-registry.descriptor.core.test.jsx src/tests/core/view-registry.entrypoint.core.test.jsx src/tests/core/collections-domain.core.test.jsx src/tests/core/collections-field-registry.core.test.jsx src/tests/core/reference-api.core.test.jsx src/tests/core/dispatches-route-adapter.core.test.jsx",
    "test:frontend:core:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=frontend --lane-group=core",
    "test:frontend:conformance": "pnpm --filter frontend exec vitest run src/tests/module-conformance/collections-crud.lifecycle.module-conformance.test.jsx src/tests/module-conformance/collections-crud.reference-policies.module-conformance.test.jsx src/tests/module-conformance/collections-crud.validation-diagnostics.module-conformance.test.jsx",
    "test:frontend:conformance:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=frontend --lane-group=conformance",
    "test:frontend:integration": "pnpm --filter frontend exec vitest run src/tests/app-integration/app-shell-routing.navigation.integration.test.jsx src/tests/app-integration/app-shell-routing.actions.integration.test.jsx src/tests/app-integration/app-shell-hydration.integration.test.jsx src/tests/app-integration/module-settings.integration.test.jsx src/tests/app-integration/module-lifecycle-runtime.integration.test.jsx src/tests/app-integration/module-lifecycle-collection-availability.integration.test.jsx src/tests/app-integration/mission-operator.integration.test.jsx src/tests/app-integration/deploy-remotes.integration.test.jsx src/tests/app-integration/products-taxonomies.integration.test.jsx",
    "test:frontend:integration:dynamic": "node scripts/test-lane-dynamic-runner.mjs --target=frontend --lane-group=integration",
    "lint:repo-loc": "node scripts/lint-repo-max-loc.mjs --max-lines=600",
    "lint:function-shape": "node scripts/lint-function-shape.mjs --max-function-lines=120 --max-complexity=20",
    "test:e2e:smoke": "node scripts/e2e-smoke-runner.mjs",
    "test": "pnpm -r test",
    "quality:protocol": "node scripts/protocol-integrity-check.mjs",
    "mission:replay-gate": "node scripts/verify-mission-replay-gate.mjs",
    "quality:gate": "node scripts/quality-gate.mjs",
    "quality:gate:full": "node scripts/quality-gate.mjs --full"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "eslint": "^9.39.1"
  }
}

