          {
            "value": "restrict",
            "label": "Restrict"
          },
          {
            "value": "nullify",
            "label": "Nullify"
          }
        ],
        "description": "Policy applied when deleting drill runs referenced by incidents."
      },
      {
        "id": "naming",
        "label": "Naming",
        "type": "object",
        "required": true,
        "defaultValue": {
          "slug": {
            "maxLength": 32,
            "prefix": "pbk"
          }
        },
        "fields": [
          {
            "id": "slug",
            "label": "Slug",
            "type": "object",
            "required": true,
            "fields": [
              {
                "id": "maxLength",
                "label": "Max Length",
                "type": "number",
                "required": true,
                "min": 8,
                "max": 120,
                "defaultValue": 32
              },
              {
                "id": "prefix",
                "label": "Prefix",
                "type": "text",
                "required": true,
                "defaultValue": "pbk"
              }
            ]
