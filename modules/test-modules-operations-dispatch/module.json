          {
            "value": "restrict",
            "label": "Restrict"
          },
          {
            "value": "nullify",
            "label": "Nullify"
          }
        ],
        "description": "Policy applied when deleting playbook runs referenced by findings."
      },
      {
        "id": "slugMaxLength",
