            "label": "Auto Escalate",
            "type": "boolean",
            "required": true,
            "defaultValue": false
          }
        ]
      },
      {
        "id": "editorialMode",
        "label": "Editorial Mode",
        "type": "enum",
        "required": true,
        "options": [
          {
            "value": "standard",
            "label": "Standard"
          },
          {
            "value": "strict",
            "label": "Strict"
          }
        ],
        "defaultValue": "standard",
        "description": "Controls dispatch validation strictness for editorial workflows."
      },
      {
        "id": "incidentDeletePolicy",
